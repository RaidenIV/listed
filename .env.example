# Local development does NOT require any of these — the app falls back to an
# in-memory store when DATABASE_URL is absent.
#
# On Railway, add a PostgreSQL service and Railway will inject DATABASE_URL
# automatically. You can also paste a connection string here for local testing.

# DATABASE_URL=postgresql://user:password@host:5432/dbname
# PORT=3000
# PGSSL=disable   # set to "disable" only for a local Postgres without TLS
